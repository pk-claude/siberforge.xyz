// ============================================================================
// Utilities: monthly resample, alignment, correlation, cross-corr
// ============================================================================

function resampleMonthly(obs) {
  // Last observation per calendar month, dated YYYY-MM-01.
  if (!obs || !obs.length) return [];
  const byMonth = new Map();
  for (const o of obs) {
    if (!Number.isFinite(o.value)) continue;
    const k = String(o.date).slice(0, 7);
    byMonth.set(k, o.value);
  }
  return [...byMonth.entries()]
    .sort((a, b) => a[0].localeCompare(b[0]))
    .map(([m, v]) => ({ date: `${m}-01`, value: v }));
}

function buildPanel(seriesMap) {
  // Returns { months: [...YYYY-MM...], cols: { id: [val_per_month_or_NaN] } }
  // First, monthly-resample each transformed series.
  const perId = {};
  const monthSet = new Set();
  for (const n of NODES) {
    const raw = (seriesMap[n.fid] && seriesMap[n.fid].observations) || [];
    let monthly = resampleMonthly(raw);
    if (n.tx === 'yoy') {
      const yoy = applyTransform(monthly, 'yoy');
      monthly = yoy;
    } else if (n.tx === 'level') {
      // already level
    } else {
      const t = applyTransform(monthly, n.tx);
      monthly = t;
    }
    perId[n.id] = monthly;
    monthly.forEach(o => monthSet.add(o.date));
  }
  const months = [...monthSet].sort();
  const cols = {};
  for (const id of Object.keys(perId)) {
    const lookup = new Map(perId[id].map(o => [o.date, o.value]));
    cols[id] = months.map(m => {
      const v = lookup.get(m);
      return Number.isFinite(v) ? v : NaN;
    });
  }
  return { months, cols };
}

function pearson(x, y) {
  let n = 0, sx = 0, sy = 0, sxx = 0, syy = 0, sxy = 0;
  for (let i = 0; i < x.length; i++) {
    const xi = x[i], yi = y[i];
    if (!Number.isFinite(xi) || !Number.isFinite(yi)) continue;
    n++;
    sx += xi; sy += yi;
    sxx += xi * xi; syy += yi * yi; sxy += xi * yi;
  }
  if (n < 12) return NaN;
  const num = sxy - (sx * sy) / n;
  const den = Math.sqrt((sxx - sx * sx / n) * (syy - sy * sy / n));
  if (den <= 0 || !Number.isFinite(den)) return NaN;
  return num / den;
}

function trailingCorr(x, y, n = 60) {
  // Use last `n` aligned non-NaN pairs.
  const pairs = [];
  for (let i = 0; i < x.length; i++) {
    if (Number.isFinite(x[i]) && Number.isFinite(y[i])) pairs.push([x[i], y[i]]);
  }
  if (pairs.length < 12) return NaN;
  const tail = pairs.slice(-n);
  if (tail.length < 12) return NaN;
  return pearson(tail.map(p => p[0]), tail.map(p => p[1]));
}

function peakLag(x, y, maxLag = 12, minObs = 24) {
  // Positive k: x leads y by k months (compare x[i] vs y[i+k]).
  let bestK = 0, bestC = 0;
  for (let k = -maxLag; k <= maxLag; k++) {
    let xs, ys;
    if (k > 0)      { xs = x.slice(0, -k); ys = y.slice(k); }
    else if (k < 0) { xs = x.slice(-k);    ys = y.slice(0, k); }
    else            { xs = x;              ys = y; }
    // count valid pairs
    let valid = 0;
    for (let i = 0; i < xs.length; i++) {
      if (Number.isFinite(xs[i]) && Number.isFinite(ys[i])) valid++;
    }
    if (valid < minObs) continue;
    const c = pearson(xs, ys);
    if (Number.isFinite(c) && Math.abs(c) > Math.abs(bestC)) { bestK = k; bestC = c; }
  }
  return { lag: bestK, corr: bestC };
}

// ============================================================================
// Render helpers
// ============================================================================

const W = 680, H = 600, CX = W / 2, CY = H / 2;
const SVG_NS = 'http://www.w3.org/2000/svg';

function clusterAngleFor(sec) {
  const ord = ['mon','inf','mkt','cdh','lab','grw'];
  const i = ord.indexOf(sec);
  return Math.PI / 2 - (i / ord.length) * 2 * Math.PI;
}

function fmtVal(v, unit) {
  if (v == null || !Number.isFinite(v)) return '—';
  let s;
  if (Math.abs(v) >= 10000)      s = (v / 1000).toFixed(1) + 'k';
  else if (Math.abs(v) >= 100)   s = v.toFixed(1);
  else if (Math.abs(v) >= 10)    s = v.toFixed(2);
  else                            s = v.toFixed(2);
  if (unit === '%')  return s + '%';
  if (unit === 'pp') return s + 'pp';
  if (unit === 'k')  return Math.round(v).toLocaleString() + 'k';
  return s;
}
function fmtPct(v) {
  if (v == null || !Number.isFinite(v)) return '—';
  return (v >= 0 ? '+' : '') + v.toFixed(2) + '%';
}

// ============================================================================
// State
// ============================================================================

const state = {
  panel: null,           // { months, cols }
  edges: [],             // computed: { s, t, w, sign, lag, pc, rc }
  recSignals: null,      // computeRecSignals output
  pinned: null,          // selected node id
  filter: { mon:1, inf:1, grw:1, lab:1, mkt:1, cdh:1 },
  options: { window: 60, minCorr: 0.2, showLags: true },
  layout: {},            // node positions
  dragging: null,
};

// ============================================================================
// Data fetch + recompute
// ============================================================================

async function loadAll() {
  const allIds = new Set(NODES.map(n => n.fid));
  for (const s of REC_SERIES) allIds.add(s);
  const start = '2010-01-01'; // long enough for 120m windows; ICSA/SAHM live further back

  let map;
  try {
    map = await fetchFred([...allIds], { start });
  } catch (err) {
    console.error('FRED fetch failed', err);
    document.getElementById('net-status').textContent = 'Failed to load FRED data: ' + err.message;
    document.getElementById('refresh-text').textContent = 'Data error';
    document.getElementById('refresh-indicator').classList.add('error');
    return;
  }

  // Build panel for correlations.
  state.panel = buildPanel(map);

  // Compute recession composite (uses raw obs of REC_SERIES).
  const rawRec = {};
  for (const id of REC_SERIES) rawRec[id] = (map[id] && map[id].observations) || [];
  state.recSignals = computeRecSignals(rawRec);

  // Cache per-node latest level + YoY for the detail panel.
  for (const n of NODES) {
    const raw = (map[n.fid] && map[n.fid].observations) || [];
    const lastValid = [...raw].reverse().find(o => Number.isFinite(o.value));
    n._latest = lastValid ? { value: lastValid.value, date: lastValid.date } : null;
    if (n.tx === 'yoy' || n.tx === 'level') {
      const yoy = applyTransform(raw, 'yoy');
      const lastYoY = [...yoy].reverse().find(o => Number.isFinite(o.value));
      n._yoy = lastYoY ? lastYoY.value : null;
    }
    // mark recession-signal triggered state (set from computeRecSignals matching by id)
    // matching: sahm→SAHMCURRENT, curve→T10Y3M, hys→BAMLH0A0HYM2 (others not in the network)
    const sig = state.recSignals.signals.find(s => {
      if (n.id === 'sahm'  && s.id === 'sahm')  return true;
      if (n.id === 'curve' && s.id === 'curve') return true;
      if (n.id === 'hys'   && s.id === 'hyoas') return true;
      return false;
    });
    n._triggered = sig ? sig.triggered : false;
  }

  // Recompute edges (initial pass).
  recomputeEdges();
  initLayout();
  renderRecBar();
  renderLegend();
  renderNetwork();

  document.getElementById('net-status').classList.add('hidden');
  document.getElementById('refresh-text').textContent = 'Live · FRED';
  document.getElementById('refresh-indicator').classList.add('live');
  document.getElementById('last-updated').textContent = 'Computed ' + new Date().toLocaleString();
}

function recomputeEdges() {
  const { cols } = state.panel;
  const win = state.options.window;
  state.edges = EDGE_DEFS.map(([s, t, expected]) => {
    const xs = cols[s], ys = cols[t];
    const rc = trailingCorr(xs, ys, win);
    const pl = peakLag(xs, ys, 12, 24);
    const signRC = Number.isFinite(rc) && rc >= 0 ? '+' : '-';
    const signPC = pl.corr >= 0 ? '+' : '-';
    const signAgree = signRC === signPC;
    const showArrow = state.options.showLags && Number.isFinite(rc)
      && Math.abs(pl.corr) >= 0.5 && Math.abs(pl.lag) >= 2 && signAgree;
    return {
      s, t, expected,
      rc: Number.isFinite(rc) ? rc : null,
      w: Number.isFinite(rc) ? Math.abs(rc) : 0,
      sign: signRC,
      pc: pl.corr,
      lag: showArrow ? pl.lag : 0,
    };
  });
}

// ============================================================================
// Layout (initial radial + force simulation)
// ============================================================================

function initLayout() {
  const byCluster = {};
  for (const n of NODES) (byCluster[n.sec] = byCluster[n.sec] || []).push(n);
  const R = 200;
  Object.keys(byCluster).forEach(sec => {
    const angle = clusterAngleFor(sec);
    const cx = CX + R * Math.cos(angle);
    const cy = CY - R * Math.sin(angle);
    const arr = byCluster[sec];
    arr.forEach((n, i) => {
      const a = (i / arr.length) * 2 * Math.PI;
      state.layout[n.id] = {
        x: cx + 55 * Math.cos(a),
        y: cy + 55 * Math.sin(a),
        vx: 0, vy: 0, fx: null, fy: null, r: 8,
      };
    });
  });
}

function tick() {
  const REPULSE = 2400, SPRING = 0.018, GRAV = 0.008, DAMP = 0.82;
  const layoutArr = NODES.map(n => state.layout[n.id]);
  // repulsion
  for (let i = 0; i < layoutArr.length; i++) {
    for (let j = i + 1; j < layoutArr.length; j++) {
      const a = layoutArr[i], b = layoutArr[j];
      const dx = b.x - a.x, dy = b.y - a.y;
      const d2 = dx * dx + dy * dy + 0.01;
      const d = Math.sqrt(d2);
      const f = REPULSE / d2;
      const fx = (f * dx) / d, fy = (f * dy) / d;
      if (a.fx == null) { a.vx -= fx; a.vy -= fy; }
      if (b.fx == null) { b.vx += fx; b.vy += fy; }
    }
  }
  // spring forces from edges (use state.edges; weaker rest length for stronger correlations)
  for (const e of state.edges) {
    const a = state.layout[e.s], b = state.layout[e.t];
    if (!a || !b) continue;
    const dx = b.x - a.x, dy = b.y - a.y;
    const d = Math.sqrt(dx * dx + dy * dy) + 0.01;
    const rest = 70 * (0.7 + 0.6 * (1 - e.w));
    const f = SPRING * (d - rest);
    const fx = (f * dx) / d, fy = (f * dy) / d;
    if (a.fx == null) { a.vx += fx; a.vy += fy; }
    if (b.fx == null) { b.vx -= fx; b.vy -= fy; }
  }
  // gravity + integrate
  for (const a of layoutArr) {
    if (a.fx != null) { a.x = a.fx; a.y = a.fy; a.vx = 0; a.vy = 0; continue; }
    a.vx += (CX - a.x) * GRAV;
    a.vy += (CY - a.y) * GRAV;
    a.vx *= DAMP; a.vy *= DAMP;
    a.x += a.vx; a.y += a.vy;
    const m = 26;
    a.x = Math.max(m, Math.min(W - m, a.x));
    a.y = Math.max(m + 12, Math.min(H - m, a.y));
  }
  applyTransforms();
  state.frame++;
  if (state.frame < 400 || state.dragging) requestAnimationFrame(tick);
}

// ============================================================================
// SVG rendering
// ============================================================================

function renderLegend() {
  const root = document.getElementById('net-legend');
  root.innerHTML = '';
  for (const [k, sec] of Object.entries(SECTORS)) {
    const b = document.createElement('button');
    b.className = 'net-chip';
    b.dataset.on = '1';
    b.dataset.sec = k;
    b.innerHTML = `<span class="dot" style="background:${sec.color}"></span>${sec.name} <a href="${sec.page}" title="Open ${sec.name} dashboard" onclick="event.stopPropagation()">page&rarr;</a>`;
    b.addEventListener('click', () => {
      state.filter[k] = state.filter[k] ? 0 : 1;
      b.dataset.on = state.filter[k];
      applyFilter();
    });
    root.appendChild(b);
  }
}

function renderNetwork() {
  const gE = document.getElementById('edges-g');
  const gL = document.getElementById('lags-g');
  const gN = document.getElementById('nodes-g');
  gE.innerHTML = ''; gL.innerHTML = ''; gN.innerHTML = '';

  // degree
  const deg = {};
  NODES.forEach(n => deg[n.id] = 0);
  state.edges.forEach(e => { deg[e.s]++; deg[e.t]++; });
  state._deg = deg;

  // edges
  state.edgeEls = state.edges.map(e => {
    const path = document.createElementNS(SVG_NS, 'path');
    path.setAttribute('class', 'edge');
    path.setAttribute('stroke', e.sign === '+' ? 'var(--green)' : 'var(--red)');
    path.setAttribute('stroke-width', (0.6 + e.w * 2.4).toFixed(2));
    path.setAttribute('opacity', (0.18 + e.w * 0.5).toFixed(2));
    if (e.lag !== 0) {
      path.setAttribute('marker-end', e.sign === '+' ? 'url(#arrPos)' : 'url(#arrNeg)');
    }
    path.dataset.s = e.s;
    path.dataset.t = e.t;
    path.addEventListener('click', ev => {
      ev.stopPropagation();
      // Edge clicks deep-link into /core/econ/compare.html (macro × macro).
      // Only open when BOTH endpoints have a registered drilldown id;
      // compare.html otherwise falls back to its defaults.
      const aN = NODES.find(n => n.id === e.s);
      const bN = NODES.find(n => n.id === e.t);
      if (aN.dl && bN.dl && DRILLDOWN_REGISTRY.has(aN.dl) && DRILLDOWN_REGISTRY.has(bN.dl)) {
        const u = `/core/econ/compare.html?a=${encodeURIComponent(aN.dl)}&b=${encodeURIComponent(bN.dl)}`;
        window.open(u, '_blank', 'noopener');
      } else {
        // Soft signal: pin the more interesting endpoint and let the user click through manually.
        state.pinned = e.s;
        highlight(e.s);
        showDetail(aN);
      }
    });
    gE.appendChild(path);
    return path;
  });

  // lag labels
  state.lagEls = state.edges.map(e => {
    if (e.lag === 0) return null;
    const t = document.createElementNS(SVG_NS, 'text');
    t.setAttribute('class', 'lagLbl');
    t.textContent = Math.abs(e.lag) + 'm';
    gL.appendChild(t);
    return t;
  });

  // nodes
  state.nodeEls = NODES.map(n => {
    const g = document.createElementNS(SVG_NS, 'g');
    g.setAttribute('class', 'node' + (n.recSig ? ' recsig' : '') + (n._triggered ? ' triggered' : ''));
    g.dataset.id = n.id;
    const r = 7 + Math.sqrt(deg[n.id] || 1) * 2.4;
    state.layout[n.id].r = r;
    const c = document.createElementNS(SVG_NS, 'circle');
    c.setAttribute('r', r.toFixed(1));
    c.setAttribute('fill', SECTORS[n.sec].color);
    c.setAttribute('opacity', '0.92');
    if (!n.recSig) {
      c.setAttribute('stroke', 'var(--panel)');
      c.setAttribute('stroke-width', '1.5');
    }
    const t = document.createElementNS(SVG_NS, 'text');
    t.setAttribute('y', -(r + 5));
    t.setAttribute('text-anchor', 'middle');
    t.textContent = n.label;
    g.appendChild(c); g.appendChild(t);

    // pointer/click handlers
    g.addEventListener('mousedown', ev => onNodeDown(ev, n));
    g.addEventListener('mouseenter', () => { if (!state.pinned) highlight(n.id); });
    g.addEventListener('mouseleave', () => { if (!state.pinned) clearHighlight(); });
    g.addEventListener('click', ev => {
      ev.stopPropagation();
      if (state._wasDragged) { state._wasDragged = false; return; }
      state.pinned = n.id;
      highlight(n.id);
      showDetail(n);
    });

    gN.appendChild(g);
    return g;
  });

  state.frame = 0;
  applyFilter();
  applyTransforms();
  requestAnimationFrame(tick);
}

function applyTransforms() {
  // node positions
  NODES.forEach((n, i) => {
    const p = state.layout[n.id];
    state.nodeEls[i].setAttribute('transform', `translate(${p.x.toFixed(1)},${p.y.toFixed(1)})`);
  });
  // edge paths
  state.edges.forEach((e, i) => {
    const a = state.layout[e.s], b = state.layout[e.t];
    let from, to;
    if (e.lag > 0)      { from = a; to = b; }
    else if (e.lag < 0) { from = b; to = a; }
    else                { from = a; to = b; }
    const dx = to.x - from.x, dy = to.y - from.y;
    const len = Math.sqrt(dx * dx + dy * dy) + 0.01;
    const ux = dx / len, uy = dy / len;
    const sx = from.x + ux * from.r;
    const sy = from.y + uy * from.r;
    const ex = to.x   - ux * (to.r + (e.lag !== 0 ? 5 : 0));
    const ey = to.y   - uy * (to.r + (e.lag !== 0 ? 5 : 0));
    const mx = (sx + ex) / 2, my = (sy + ey) / 2;
    const cx = mx - (ey - sy) * 0.06;
    const cy = my + (ex - sx) * 0.06;
    state.edgeEls[i].setAttribute('d',
      `M${sx.toFixed(1)} ${sy.toFixed(1)} Q ${cx.toFixed(1)} ${cy.toFixed(1)} ${ex.toFixed(1)} ${ey.toFixed(1)}`
    );
    if (state.lagEls[i]) {
      const t = 0.5;
      const lx = (1 - t) * (1 - t) * sx + 2 * (1 - t) * t * cx + t * t * ex;
      const ly = (1 - t) * (1 - t) * sy + 2 * (1 - t) * t * cy + t * t * ey - 3;
      state.lagEls[i].setAttribute('x', lx.toFixed(1));
      state.lagEls[i].setAttribute('y', ly.toFixed(1));
    }
  });
}

function applyFilter() {
  const minC = state.options.minCorr;
  NODES.forEach((n, i) => {
    state.nodeEls[i].classList.toggle('muted', !state.filter[n.sec]);
  });
  state.edges.forEach((e, i) => {
    const ns = NODES.find(n => n.id === e.s).sec;
    const nt = NODES.find(n => n.id === e.t).sec;
    const visible = state.filter[ns] && state.filter[nt] && Math.abs(e.rc || 0) >= minC;
    state.edgeEls[i].setAttribute('opacity', visible ? (0.18 + e.w * 0.5).toFixed(2) : '0.02');
    if (state.lagEls[i]) {
      state.lagEls[i].setAttribute('opacity', visible ? '0.9' : '0');
    }
  });
}

function highlight(id) {
  const neighbors = new Set([id]);
  state.edges.forEach((e, i) => {
    const hot = (e.s === id || e.t === id);
    if (hot) {
      state.edgeEls[i].setAttribute('opacity', '1');
      state.edgeEls[i].setAttribute('stroke-width', (1.4 + e.w * 2.4).toFixed(2));
      neighbors.add(e.s); neighbors.add(e.t);
      if (state.lagEls[i]) { state.lagEls[i].classList.add('hot'); state.lagEls[i].setAttribute('opacity', '1'); }
    } else {
      state.edgeEls[i].setAttribute('opacity', '0.04');
      if (state.lagEls[i]) { state.lagEls[i].classList.remove('hot'); state.lagEls[i].setAttribute('opacity', '0'); }
    }
  });
  NODES.forEach((n, i) => {
    state.nodeEls[i].classList.toggle('muted', !neighbors.has(n.id) || !state.filter[n.sec]);
  });
}
function clearHighlight() {
  state.edges.forEach((e, i) => {
    state.edgeEls[i].setAttribute('stroke-width', (0.6 + e.w * 2.4).toFixed(2));
    if (state.lagEls[i]) state.lagEls[i].classList.remove('hot');
  });
  applyFilter();
}

// ============================================================================
// Drag, click, detail panel
// ============================================================================

function svgPoint(evt) {
  const svg = document.getElementById('net');
  const pt = svg.createSVGPoint();
  pt.x = evt.clientX; pt.y = evt.clientY;
  const m = svg.getScreenCTM().inverse();
  return pt.matrixTransform(m);
}

function onNodeDown(ev, n) {
  ev.preventDefault();
  state.dragging = state.layout[n.id];
  state._dragStart = { x: ev.clientX, y: ev.clientY };
  state._wasDragged = false;
  document.querySelector(`.node[data-id="${n.id}"]`).classList.add('dragging');
  const p = svgPoint(ev);
  state.dragging.fx = p.x; state.dragging.fy = p.y;
  requestAnimationFrame(tick);
}

window.addEventListener('mousemove', ev => {
  if (!state.dragging) return;
  const p = svgPoint(ev);
  state.dragging.fx = p.x; state.dragging.fy = p.y;
  if (state._dragStart) {
    const dx = ev.clientX - state._dragStart.x;
    const dy = ev.clientY - state._dragStart.y;
    if (dx * dx + dy * dy > 9) state._wasDragged = true;
  }
});
window.addEventListener('mouseup', () => {
  if (state.dragging) {
    state.dragging.fx = null; state.dragging.fy = null;
    state.dragging = null;
    document.querySelectorAll('.node.dragging').forEach(g => g.classList.remove('dragging'));
  }
});
document.getElementById('net').addEventListener('click', () => {
  state.pinned = null; clearHighlight(); resetDetail();
});

function showDetail(n) {
  document.getElementById('nd-title').textContent = n.label;
  document.getElementById('nd-sub').textContent = `${SECTORS[n.sec].name} · ${state._deg[n.id]} edges`;
  document.getElementById('nd-body').style.display = 'block';
  document.getElementById('nd-val').textContent  = n._latest ? fmtVal(n._latest.value, n.unit) : '—';
  document.getElementById('nd-yoy').textContent  = fmtPct(n._yoy);
  document.getElementById('nd-asof').textContent = n._latest ? n._latest.date : '—';
  document.getElementById('nd-sec').textContent  = SECTORS[n.sec].name;
  document.getElementById('nd-src').textContent  = n.fid;
  document.getElementById('nd-deg').textContent  = state._deg[n.id];
  // Drilldown CTA: link to internal indicator page if registered, else to FRED.
  const ctaEl = document.getElementById('nd-cta-drill');
  if (n.dl && DRILLDOWN_REGISTRY.has(n.dl)) {
    ctaEl.setAttribute('href', `/core/econ/indicator.html?id=${encodeURIComponent(n.dl)}`);
    ctaEl.textContent = 'Open indicator drilldown →';
  } else {
    ctaEl.setAttribute('href', fredUrl(n.fid));
    ctaEl.textContent = `View on FRED (${n.fid}) →`;
  }

  // Build directional link tags.
  const inLinks = [], outLinks = [], coLinks = [];
  for (const e of state.edges) {
    if (e.s === n.id) {
      if (e.lag > 0)      outLinks.push({ e, other: e.t, lag: e.lag });
      else if (e.lag < 0) inLinks.push({ e, other: e.t, lag: -e.lag });
      else                coLinks.push({ e, other: e.t, lag: 0 });
    } else if (e.t === n.id) {
      if (e.lag > 0)      inLinks.push({ e, other: e.s, lag: e.lag });
      else if (e.lag < 0) outLinks.push({ e, other: e.s, lag: -e.lag });
      else                coLinks.push({ e, other: e.s, lag: 0 });
    }
  }
  function chips(arr) {
    return arr.map(it => {
      const e = it.e, otherNode = NODES.find(nn => nn.id === it.other);
      const cls = e.sign === '+' ? 'pos' : 'neg';
      const corr = Number.isFinite(e.rc) ? Math.round(Math.abs(e.rc) * 100) : '—';
      const lagStr = it.lag ? `<span class="nd-lag">·${it.lag}m</span>` : '';
      return `<span class="nd-tag ${cls}" data-id="${otherNode.id}">${e.sign} ${otherNode.label} <span class="nd-lag">(${corr})</span>${lagStr}</span>`;
    }).join('');
  }
  let html = '';
  if (outLinks.length) html += `<span class="label">Leads &rarr;</span>${chips(outLinks)}`;
  if (inLinks.length)  html += `<span class="label">Lags &larr;</span>${chips(inLinks)}`;
  if (coLinks.length)  html += `<span class="label">Coincident</span>${chips(coLinks)}`;
  if (!html) html = '<div class="nd-empty">No connections in current view.</div>';
  document.getElementById('nd-links').innerHTML = html;
  // wire chip clicks
  document.getElementById('nd-links').querySelectorAll('.nd-tag').forEach(t => {
    t.addEventListener('click', ev => {
      ev.stopPropagation();
      const otherId = t.dataset.id;
      state.pinned = otherId;
      highlight(otherId);
      showDetail(NODES.find(nn => nn.id === otherId));
    });
  });
}
function resetDetail() {
  document.getElementById('nd-title').textContent = 'Click a node to inspect';
  document.getElementById('nd-sub').textContent = 'Hover highlights the neighborhood. Click a node to pin its detail; click any tag below to walk the graph.';
  document.getElementById('nd-body').style.display = 'none';
}

// ============================================================================
// Recession-composite bar (mirrors landing-page strip)
// ============================================================================

function renderRecBar() {
  const triggered = state.recSignals.signals.filter(s => s.triggered).length;
  const tier = recTierOf(triggered);
  document.getElementById('rec-count').textContent = String(triggered);
  const tEl = document.getElementById('rec-tier');
  tEl.textContent = tier.label;
  tEl.classList.remove('tier-benign','tier-low','tier-elevated','tier-high');
  tEl.classList.add(tier.cls);

  const dotsRoot = document.getElementById('rec-dots');
  dotsRoot.innerHTML = state.recSignals.signals.map(s => {
    return `<span class="rec-bar-dot ${s.triggered ? 'triggered' : ''}" title="${s.label}: ${s.triggered ? 'TRIGGERED' : 'OK'}"></span>`;
  }).join('');

  const latest = state.recSignals.signals.map(s => s.currentDate).filter(Boolean).sort().pop();
  document.getElementById('rec-asof').textContent = latest ? `as-of ${latest}` : '';
}

// ============================================================================
// Controls
// ============================================================================

document.getElementById('net-window').addEventListener('change', ev => {
  state.options.window = parseInt(ev.target.value, 10);
  recomputeEdges();
  renderNetwork();
});
document.getElementById('net-min-corr').addEventListener('change', ev => {
  state.options.minCorr = parseFloat(ev.target.value);
  applyFilter();
});
document.getElementById('net-show-lags').addEventListener('change', ev => {
  state.options.showLags = ev.target.value === '1';
  recomputeEdges();
  renderNetwork();
});
document.getElementById('net-reset').addEventListener('click', () => {
  initLayout();
  state.frame = 0;
  requestAnimationFrame(tick);
});

// ============================================================================
// Boot
// ============================================================================

loadAll();
</script>

