<script type="module">
import { fetchFred } from '/core/lib/fred-client.js';
import { applyTransform } from '/core/lib/transforms.js';
import {
  SERIES as REC_SERIES,
  HISTORY_START as REC_HISTORY,
  tierOf as recTierOf,
  computeSignals as computeRecSignals,
} from '/core/econ/recession-core.js';

// ============================================================================
// Configuration: nodes, sectors, edges
// ============================================================================

// Indicator-drilldown registry — IDs that have a /core/econ/indicator.html?id= page.
// Pulled from indicators.js. Update this set when the registry expands.
const DRILLDOWN_REGISTRY = new Set([
  'AHE','CPILFESL','CSUSHPISA','DGS2','DGS5','DRCCLACBS','EMPIRE','EXHOSLUS',
  'GDPC1','GDPNOW','HOUST','HSN1F','IC4WSA','INDPRO','MORTGAGE30US','PAYEMS',
  'PCEPILFE','PERMIT','REAL_WAGES','RRSFS','STICKY','T10Y2Y','T10Y3M','T5YIFR','UNRATE',
]);
// Build the FRED-website fallback URL.
const fredUrl = (fid) => `https://fred.stlouisfed.org/series/${encodeURIComponent(fid)}`;

const SECTORS = {
  mon: { name: 'Monetary policy', color: '#7c5cd6', page: '/core/macro/cycle/' },
  inf: { name: 'Inflation',        color: '#e07a5f', page: '/core/macro/inflation/' },
  grw: { name: 'Growth & Consumer',color: '#3aa39e', page: '/core/macro/real-economy/' },
  lab: { name: 'Labor',            color: '#3a7bd5', page: '/core/macro/labor/' },
  mkt: { name: 'Markets',          color: '#d99a2b', page: '/core/macro/research.html' },
  cdh: { name: 'Credit & Housing', color: '#cf5d8f', page: '/core/macro/credit/' },
};

// Each node:
//   id     — short graph id
//   fid    — FRED series id (used for fetchFred)
//   tx     — 'level' | 'yoy' | 'mom_diff_k' (passed to applyTransform)
//   sec    — sector key
//   label  — display name
//   unit   — '%' | 'pp' | 'k' | '' for formatting
//   dl     — id used in /core/econ/indicator.html?id=DL (often == fid; some pages use aliases)
//   recSig — true if part of the 5-signal recession composite
const NODES = [
  // monetary
  { id: 'fed',     fid: 'DFF',         tx: 'level', sec: 'mon', label: 'Fed Funds',         unit: '%',  dl: '' },
  { id: 'm2',      fid: 'M2SL',        tx: 'yoy',   sec: 'mon', label: 'M2 Money (YoY)',    unit: '%',  dl: '' },
  { id: 'gs2',     fid: 'DGS2',        tx: 'level', sec: 'mon', label: '2Y Treasury',       unit: '%',  dl: 'DGS2' },
  { id: 'gs10',    fid: 'DGS10',       tx: 'level', sec: 'mon', label: '10Y Treasury',      unit: '%',  dl: '' },
  { id: 'curve',   fid: 'T10Y3M',      tx: 'level', sec: 'mon', label: 'Curve 10Y-3M',      unit: '%',  dl: 'T10Y3M', recSig: true },

  // inflation
  { id: 'cpi',     fid: 'CPIAUCSL',    tx: 'yoy',   sec: 'inf', label: 'Headline CPI',      unit: '%',  dl: 'CPIAUCSL' },
  { id: 'corecpi', fid: 'CPILFESL',    tx: 'yoy',   sec: 'inf', label: 'Core CPI',          unit: '%',  dl: 'CPILFESL' },
  { id: 'pce',     fid: 'PCEPILFE',    tx: 'yoy',   sec: 'inf', label: 'Core PCE',          unit: '%',  dl: 'PCEPILFE' },
  { id: 'ppi',     fid: 'PPIACO',      tx: 'yoy',   sec: 'inf', label: 'PPI',               unit: '%',  dl: 'PPIACO' },
  { id: 'wage',    fid: 'CES0500000003',tx: 'yoy',  sec: 'inf', label: 'Avg Hourly Earn.',  unit: '%',  dl: 'AHE' },
  { id: 'infx',    fid: 'T5YIE',       tx: 'level', sec: 'inf', label: '5Y Infl. Exp.',     unit: '%',  dl: 'T5YIE' },

  // growth & consumer
  { id: 'gdp',     fid: 'GDPC1',       tx: 'yoy',   sec: 'grw', label: 'Real GDP',          unit: '%',  dl: 'GDPC1' },
  { id: 'ip',      fid: 'INDPRO',      tx: 'yoy',   sec: 'grw', label: 'Industrial Prod.',  unit: '%',  dl: 'INDPRO' },
  { id: 'rs',      fid: 'RRSFS',       tx: 'yoy',   sec: 'grw', label: 'Real Retail Sales', unit: '%',  dl: 'RRSFS' },
  { id: 'capu',    fid: 'CUMFNS',      tx: 'level', sec: 'grw', label: 'Capacity Utiliz.',  unit: '%',  dl: 'CUMFNS' },
  { id: 'savings', fid: 'PSAVERT',     tx: 'level', sec: 'grw', label: 'Savings Rate',      unit: '%',  dl: 'PSAVERT' },

  // labor
  { id: 'unr',     fid: 'UNRATE',      tx: 'level', sec: 'lab', label: 'Unemployment',      unit: '%',  dl: 'UNRATE' },
  { id: 'nfp',     fid: 'PAYEMS',      tx: 'yoy',   sec: 'lab', label: 'NFP (YoY)',         unit: '%',  dl: 'PAYEMS' },
  { id: 'jolt',    fid: 'JTSJOL',      tx: 'yoy',   sec: 'lab', label: 'JOLTS (YoY)',       unit: '%',  dl: 'JTSJOL' },
  { id: 'lfpr',    fid: 'CIVPART',     tx: 'level', sec: 'lab', label: 'Labor Force Part.', unit: '%',  dl: 'CIVPART' },
  { id: 'icsa',    fid: 'IC4WSA',      tx: 'level', sec: 'lab', label: 'Initial Claims (4w)',unit: 'k', dl: 'IC4WSA' },
  { id: 'sahm',    fid: 'SAHMCURRENT', tx: 'level', sec: 'lab', label: 'Sahm Indicator',    unit: 'pp', dl: 'SAHMCURRENT', recSig: true },

  // markets
  { id: 'spx',     fid: 'SP500',       tx: 'yoy',   sec: 'mkt', label: 'S&P 500 (YoY)',     unit: '%',  dl: 'SP500' },
  { id: 'dxy',     fid: 'DTWEXBGS',    tx: 'yoy',   sec: 'mkt', label: 'USD Broad (YoY)',   unit: '%',  dl: 'DTWEXBGS' },
  { id: 'wti',     fid: 'DCOILWTICO',  tx: 'yoy',   sec: 'mkt', label: 'WTI Crude (YoY)',   unit: '%',  dl: 'DCOILWTICO' },
  { id: 'vix',     fid: 'VIXCLS',      tx: 'level', sec: 'mkt', label: 'VIX',               unit: '',   dl: 'VIXCLS' },
  { id: 'nfci',    fid: 'NFCI',        tx: 'level', sec: 'mkt', label: 'NFCI',              unit: '',   dl: 'NFCI' },

  // credit & housing
  { id: 'hys',     fid: 'BAMLH0A0HYM2',tx: 'level', sec: 'cdh', label: 'HY OAS',            unit: '%',  dl: 'BAMLH0A0HYM2', recSig: true },
  { id: 'mort',    fid: 'MORTGAGE30US',tx: 'level', sec: 'cdh', label: '30Y Mortgage',      unit: '%',  dl: 'MORTGAGE30US' },
  { id: 'hpi',     fid: 'CSUSHPISA',   tx: 'yoy',   sec: 'cdh', label: 'Home Px (Case-S)',  unit: '%',  dl: 'CSUSHPISA' },
  { id: 'houst',   fid: 'HOUST',       tx: 'yoy',   sec: 'cdh', label: 'Housing Starts',    unit: '%',  dl: 'HOUST' },
  { id: 'permit',  fid: 'PERMIT',      tx: 'yoy',   sec: 'cdh', label: 'Building Permits',  unit: '%',  dl: 'PERMIT' },
  { id: 'recprob', fid: 'RECPROUSM156N',tx:'level', sec: 'cdh', label: 'NY Fed Rec. Prob',  unit: '%',  dl: 'RECPROUSM156N' },
];

// edges: [s, t, expected_sign] — sign is just for documentation; actual sign comes from rolling correlation
const EDGE_DEFS = [
  // monetary policy transmission
  ['fed','gs2','+'], ['fed','gs10','+'], ['fed','m2','-'],
  ['gs2','curve','-'], ['gs10','curve','+'],
  ['fed','curve','-'],
  ['fed','mort','+'], ['gs10','mort','+'],
  ['fed','spx','-'], ['fed','dxy','+'], ['fed','hys','+'],

  // inflation pillar
  ['cpi','corecpi','+'], ['corecpi','pce','+'], ['cpi','pce','+'],
  ['cpi','ppi','+'], ['cpi','infx','+'],
  ['wage','cpi','+'], ['wti','cpi','+'],
