<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Siberforge &mdash; Transmission Network</title>
<link rel="preconnect" href="https://rsms.me/" />
<link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
<link rel="stylesheet" href="./styles.css" />
<style>
/* ================================================================
   network.html — scoped styles
   ================================================================ */
.net-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 320px;
  gap: 16px;
  align-items: start;
}
@media (max-width: 980px) {
  .net-grid { grid-template-columns: 1fr; }
}
.net-wrap {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 6px;
  padding: 8px;
  position: relative;
  min-height: 620px;
}
.net-wrap svg.net {
  display: block;
  width: 100%;
  height: auto;
  user-select: none;
  cursor: default;
}
.net-status {
  position: absolute; left: 0; right: 0; top: 0; bottom: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 12.5px; color: var(--muted);
  background: var(--panel);
  z-index: 5;
}
.net-status.hidden { display: none; }

/* legend chips */
.net-legend { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 10px; }
.net-chip {
  font-size: 11px;
  padding: 5px 11px;
  border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--panel);
  color: var(--text);
  cursor: pointer;
  font-family: inherit;
  user-select: none;
  transition: opacity .15s, background-color .15s, border-color .15s;
}
.net-chip:hover { background: var(--panel-2); border-color: var(--muted); }
.net-chip[data-on="0"] { opacity: 0.32; }
.net-chip .dot {
  display: inline-block; width: 8px; height: 8px;
  border-radius: 50%; margin-right: 6px; vertical-align: 0px;
}
.net-chip a {
  color: inherit; text-decoration: none;
  display: inline-block; margin-left: 6px;
  border-left: 1px solid var(--line); padding-left: 6px;
  font-size: 10px; color: var(--muted);
}
.net-chip a:hover { color: var(--accent); }

/* SVG nodes & edges */
.node circle {
  transition: opacity .15s, stroke-width .15s, filter .15s;
}
.node text {
  font-family: 'Inter', sans-serif;
  font-size: 10px;
  font-weight: 500;
  fill: var(--text);
  pointer-events: none;
}
.node.muted circle, .node.muted text { opacity: 0.18; }
.node.recsig circle {
  stroke: var(--accent);
  stroke-width: 2.5;
  stroke-dasharray: 0;
}
.node.recsig.triggered circle {
  stroke: var(--red);
  filter: drop-shadow(0 0 4px rgba(239, 79, 90, 0.7));
}
.node:not(.dragging) { cursor: pointer; }
.node.dragging { cursor: grabbing; }
.edge {
  stroke-linecap: round;
  fill: none;
  pointer-events: stroke;
  cursor: pointer;
  transition: opacity .15s, stroke-width .15s;
}
.edge:hover { stroke-width: 3.5 !important; opacity: 1 !important; }
.lagLbl {
  font-family: 'Inter', sans-serif;
  font-size: 9.5px;
  fill: var(--muted);
  pointer-events: none;
  text-anchor: middle;
  font-weight: 600;
}
.lagLbl.hot { fill: var(--text); }

/* recession overlay banner */
.rec-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 6px;
  padding: 10px 14px;
  margin-bottom: 12px;
  font-size: 12px;
  flex-wrap: wrap;
}
.rec-bar-tier {
  font-weight: 700;
  letter-spacing: 1px;
  font-size: 11px;
  padding: 3px 8px;
  border-radius: 4px;
  border: 1px solid;
}
.rec-bar-tier.tier-benign   { color: var(--green);  border-color: var(--green); }
.rec-bar-tier.tier-low      { color: var(--blue);   border-color: var(--blue); }
.rec-bar-tier.tier-elevated { color: var(--accent); border-color: var(--accent); }
.rec-bar-tier.tier-high     { color: var(--red);    border-color: var(--red); }
.rec-bar-count { font-weight: 600; }
.rec-bar-dots { display: flex; gap: 4px; }
.rec-bar-dot {
  width: 8px; height: 8px; border-radius: 50%;
  background: var(--line); border: 1px solid var(--line);
}
.rec-bar-dot.triggered { background: var(--red); border-color: var(--red); }
.rec-bar-link {
  color: var(--accent);
  text-decoration: none;
  font-size: 11px;
}
.rec-bar-link:hover { text-decoration: underline; }

/* detail card */
.net-detail {
  background: var(--panel);
  border: 1px solid var(--line);
  border-radius: 6px;
  padding: 14px 16px;
  font-size: 12px;
  position: sticky;
  top: 130px;
}
.net-detail h3 {
  font-size: 14px;
  margin: 0 0 4px;
  font-weight: 600;
  letter-spacing: -0.005em;
}
.net-detail .nd-sub { color: var(--muted); font-size: 11px; }
.net-detail .nd-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 14px; margin-top: 12px;
}
.net-detail .nd-row {
  display: flex; justify-content: space-between;
  border-bottom: 1px solid var(--line);
  padding: 4px 0; gap: 8px;
}
.net-detail .nd-row span:last-child {
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  color: var(--muted);
}
.net-detail .nd-cta {
  display: inline-block;
  margin-top: 12px;
  padding: 5px 10px;
  border: 1px solid var(--line);
  border-radius: 4px;
  font-size: 11px;
  color: var(--accent);
  text-decoration: none;
}
.net-detail .nd-cta:hover { background: var(--panel-2); border-color: var(--accent); }
.net-detail .nd-links { margin-top: 12px; line-height: 1.7; }
.net-detail .nd-links .label {
  color: var(--muted);
  font-size: 10.5px;
  text-transform: uppercase;
  letter-spacing: 1px;
  display: block;
  margin: 8px 0 4px;
}
.net-detail .nd-tag {
  display: inline-block;
  padding: 3px 8px;
  border-radius: 4px;
  border: 1px solid var(--line);
  margin: 0 4px 4px 0;
  font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  font-size: 10.5px;
  cursor: pointer;
  background: var(--panel-2);
}
.net-detail .nd-tag:hover { border-color: var(--accent); }
.net-detail .nd-tag.pos { color: var(--green); }
.net-detail .nd-tag.neg { color: var(--red); }
.net-detail .nd-lag { color: var(--muted); margin-left: 4px; font-size: 9.5px; }
.net-detail .nd-empty { color: var(--muted); font-style: italic; font-size: 11px; }

/* footer note styling */
.net-foot-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
  margin: 16px 24px 0;
  padding-bottom: 16px;
  font-size: 11px;
  color: var(--muted);
  line-height: 1.55;
}
@media (max-width: 700px) { .net-foot-grid { grid-template-columns: 1fr; } }
.net-foot-grid h4 {
  font-size: 11px;
  text-transform: uppercase;
  letter-spacing: 1px;
  color: var(--text);
  margin: 0 0 6px;
  font-weight: 600;
}
.net-foot-grid p { margin: 0 0 6px; }
</style>
</head>
<body>

<header class="top">
  <div class="brand">
    <a href="/core/macro/" class="home-link" title="Back to macro dashboard">&larr;</a>
    <span class="mark">SIBERFORGE</span>
    <span class="sub">Macro &middot; Transmission Network</span>
